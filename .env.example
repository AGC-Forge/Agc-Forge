# ╔══════════════════════════════════════════════════════════════════╗
# ║                    ENVIRONMENT VARIABLES                         ║
# ║           Copy ke .env dan isi semua nilai yang dibutuhkan       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/aichat_db"

# ─────────────────────────────────────────────
# NEXTAUTH
# Generate secret: openssl rand -base64 32
# Using Python: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# OAUTH PROVIDERS
# ─────────────────────────────────────────────

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─────────────────────────────────────────────
# PUTER.JS (AI Provider)
# https://docs.puter.com/getting-started/
#
# User-Pays Model:
#   - Browser:  user login Puter sendiri (gratis untuk developer)
#   - Node.js:  perlu puterAuthToken dari akun Puter kamu
#
# Cara dapat token:
#   1. Login ke puter.com
#   2. Buka DevTools → Application → Local Storage
#   3. Cari key "auth_token"
# ─────────────────────────────────────────────
PUTER_AUTH_TOKEN=""
# ── Mode 2: Auto Token Per User (User-Pays Model) ─────────────────────────────
# Set ke "true" untuk mengaktifkan mode ini
# User harus login ke akun Puter mereka sendiri via popup browser
# Cost ditanggung oleh masing-masing user Puter (25M token gratis/bulan)
# CATATAN: Jika true, PUTER_AUTH_TOKEN tidak digunakan
PUTER_GET_AUTO_TOKEN_FROM_LOGGED_USER="false"
# ─────────────────────────────────────────────
# MINIO (S3-compatible Object Storage)
# Docker: docker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"
# ─────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="aichat-media"
MINIO_REGION="us-east-1"

# Public URL untuk akses file (jika MinIO behind reverse proxy)
# Contoh: "https://media.yourdomain.com"
# Biarkan kosong jika akses langsung ke MinIO
MINIO_PUBLIC_URL=""

# ─────────────────────────────────────────────
# REDIS (untuk caching & realtime progress job)
# Docker: docker run -p 6379:6379 redis:alpine
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# EMAIL — pilih salah satu
# ─────────────────────────────────────────────

# Opsi 1: Resend (gratis 3000 email/bulan)
# https://resend.com/
RESEND_API_KEY=""

# Opsi 2: SMTP (Gmail, Mailtrap, dll)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Email pengirim
EMAIL_FROM="AI Chat <noreply@yourdomain.com>"

# ─────────────────────────────────────────────
# ENCRYPTION (untuk simpan API key user di DB)
# Generate: openssl rand -hex 32
# ─────────────────────────────────────────────
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# ─────────────────────────────────────────────
# SEED (opsional — untuk prisma db seed)
# ─────────────────────────────────────────────
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@12345"
ADMIN_NAME="Administrator"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="AI Chat"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
# ── Client-side flag (untuk browser) ──────────────────────────────────────────
# Harus sama nilainya dengan PUTER_GET_AUTO_TOKEN_FROM_LOGGED_USER
# NEXT_PUBLIC_ prefix = terekspos ke browser
NEXT_PUBLIC_PUTER_AUTO_TOKEN="false"
# ── Test mode (untuk development tanpa credit Puter) ─────────────────────────
# Jika true: image gen return placeholder, video gen return sample
# Set ke "false" di production
PUTER_TEST_MODE="true"

SMOKE_BASE_URL="http://localhost:3000" 
SMOKE_AUTH_COOKIE="authjs.session-token=...; __Secure-authjs.session-token=..." pnpm smoke:puter-auth